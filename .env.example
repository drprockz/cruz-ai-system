# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://cruz:your_password@localhost:5432/cruz_db
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333

# ── AI Services — Cloud ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# LLM backend for CRUZ / FORGE / SENTINEL / GENERAL (Claude-hardcoded agents).
# Options: anthropic (default) | ollama | gemini
# When "ollama" — uses qwen2.5-coder:14b via /v1/chat/completions (no API cost).
# When "gemini" — uses gemini-2.5-flash (free 250 req/day).
LLM_BACKEND=anthropic
INWORLD_API_KEY=your-inworld-key

# ── AI Services — Local ───────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434

# ── Voice ─────────────────────────────────────────────────────────────────────
PICOVOICE_ACCESS_KEY=your-picovoice-key

# Wake-word backend for scripts/voice/listen.py
#   openwakeword (default) — open source, no signup, uses 'hey_jarvis' pretrained model
#   picovoice              — Porcupine; needs PICOVOICE_ACCESS_KEY + optional custom .ppn
WAKE_WORD_BACKEND=openwakeword
# Name of the keyword model to load (openwakeword built-ins:
# hey_jarvis, alexa, hey_mycroft, hey_rhasspy)
CRUZ_VOICE_KEYWORD=hey_jarvis
INWORLD_VOICE_ID=your-cloned-voice-id

# Deepgram (voice pipeline v2 — STT Nova-3 + TTS Aura-2 Orion)
DEEPGRAM_API_KEY=dg-...
DEEPGRAM_TTS_MODEL=aura-2-orion-en

# LiveKit Cloud (realtime transport for voice sessions)
LIVEKIT_API_KEY=API...
LIVEKIT_API_SECRET=...
LIVEKIT_WS_URL=wss://your-project.livekit.cloud

# ── Integrations (Phase 2+) ───────────────────────────────────────────────────
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GOOGLE_CALENDAR_ID=your-calendar-id
GOOGLE_APPLICATION_CREDENTIALS=/Users/drprockz/.config/cruz/gdrive-sa.json
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id

# When set, daily backups are moved here instead of uploaded to Drive.
# Use this when you don't have Workspace + Shared Drive (service accounts have no
# personal storage quota in Drive).
BACKUP_LOCAL_DIR=
GITHUB_TOKEN=ghp_...
NOTION_API_KEY=secret_...
PLANEIO_API_KEY=your-plane-key
PLANE_BASE_URL=https://pm.simpleinc.cloud  # self-hosted Plane instance (no trailing slash, no /api)
APOLLO_API_KEY=your-apollo-key
HUNTER_API_KEY=your-hunter-key
SENDGRID_API_KEY=SG...
EMAIL_FROM=cruz@simpleinc.cloud  # default 'from' address for ECHO/REACH sends
SLACK_BOT_TOKEN=xoxb-...
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
VERCEL_TOKEN=your-vercel-token
RAILWAY_TOKEN=your-railway-token

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=generate-with-openssl-rand-hex-32
SESSION_SECRET=generate-with-openssl-rand-hex-32

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
ENVIRONMENT=development

# Whisper model — openai/whisper-small (default, ~2s/call) or openai/whisper-large-v3 (~30s/call)
WHISPER_MODEL=small.en

# faster-whisper CTranslate2 compute type: int8 (fastest) | int8_float16 | float16 | float32
WHISPER_COMPUTE_TYPE=int8

# Google Calendar (SP3)
GCAL_CLIENT_ID=
GCAL_CLIENT_SECRET=
GCAL_TOKEN_PATH=~/.config/cruz/gcal-token.json
GCAL_DEFAULT_CALENDAR_ID=primary
